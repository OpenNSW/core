#!/usr/bin/env bash
#
# Native git pre-commit hook for github.com/OpenNSW/core
# Enable once per clone:  git config core.hooksPath .githooks   (or: make setup)
#
# Runs against STAGED changes. Auto-fixers (license headers, formatting) modify
# files and re-stage them so the fixes are part of the commit.
#
# Bypass everything:      git commit --no-verify
# Skip individual checks: SKIP=secrets,lint git commit
#   tokens: secrets license format lint mod build
#
# Partial staging: if you `git add -p` only some hunks of a .go file, the
# auto-fixers re-stage the WHOLE file. Stage whole .go files (or run the
# formatters first) to avoid pulling unstaged hunks into the commit.

set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Ensure tools installed via `go install` are on PATH without requiring
# contributors to manually add GOPATH/bin to their shell config.
# Check $GOPATH first to avoid spawning a subprocess on every hook run.
if [ -z "${GOPATH:-}" ] && command -v go >/dev/null 2>&1; then
  GOPATH="$(go env GOPATH)"
fi
if [ -n "${GOPATH:-}" ]; then
  export PATH="$GOPATH/bin:$PATH"
fi

LICENSE_TMPL=".github/license-header.tmpl"
GOLANGCI_CONFIG=".golangci.yml"
GOLANGCI_TIMEOUT="5m"

if [ -t 2 ]; then
  RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; BLD=$'\033[1m'; RST=$'\033[0m'
else RED=""; GRN=""; YLW=""; BLD=""; RST=""; fi
info() { printf '%s==>%s %s\n' "$BLD" "$RST" "$*" >&2; }
ok()   { printf '  %sok%s  %s\n' "$GRN" "$RST" "$*" >&2; }
warn() { printf '%swarn%s %s\n' "$YLW" "$RST" "$*" >&2; }
die()  { printf '%sFAIL%s %s\n' "$RED" "$RST" "$*" >&2; exit 1; }
skip() { case ",${SKIP:-}," in *,"$1",*) return 0 ;; *) return 1 ;; esac; }

need_tool() {
  command -v "$1" >/dev/null 2>&1 || die "required tool '$1' not found.
       install: $2
       (or bypass once: git commit --no-verify)"
}

info "preflight: checking tools"
need_tool go            "https://go.dev/dl/ (>= 1.26.4)"
need_tool gitleaks      "brew install gitleaks  |  https://github.com/gitleaks/gitleaks/releases"
need_tool golangci-lint "https://golangci-lint.run/welcome/install/ (v2.11.2)"
need_tool addlicense    "go install github.com/google/addlicense@latest"

# 1. Secret scan (hard gate, before any auto-fix).
if skip secrets; then warn "SKIP=secrets"; else
  info "gitleaks: scanning staged changes"
  gitleaks git --staged --redact --no-banner \
    || die "gitleaks found a potential secret (above). Remove it or add an allow rule."
  ok "no secrets"
fi

# Staged Go files: Added/Copied/Modified/Renamed (not Deleted), NUL-safe.
STAGED_GO=()
while IFS= read -r -d '' f; do STAGED_GO+=("$f"); done \
  < <(git diff --cached --name-only -z --diff-filter=ACMR -- '*.go')

if [ "${#STAGED_GO[@]}" -eq 0 ]; then
  ok "no staged .go files; skipping go checks"; exit 0
fi

# Unique parent dirs of staged Go files, split by module ownership. Resolved with
# pure Bash parameter expansion (no per-file printf/xargs/dirname/sort) to keep the
# hook fast on macOS/WSL where process spawns are expensive.
# STAGED_DIRS:      every unique staged dir, repo-relative, no "./" prefix.
# ROOT_DIRS:        dirs owned by the root module (no own go.mod in ancestry), "./"-prefixed.
# SUB_MODULE_ROOTS: de-duplicated roots of nested sub-modules that have staged files.
# Splitting is required because golangci-lint must be invoked from within a
# module's own root — passing a sub-module dir from the root context causes
# "does not contain package" typechecking errors for both fmt and run.
STAGED_DIRS=()
for f in "${STAGED_GO[@]}"; do
  d="${f%/*}"
  [[ "$d" == "$f" ]] && d="."   # file at repo root (no slash in path)
  already=false
  for existing in "${STAGED_DIRS[@]+"${STAGED_DIRS[@]}"}"; do
    [[ "$existing" == "$d" ]] && already=true && break
  done
  $already || STAGED_DIRS+=("$d")
done

# _sub_module_root <dir>: print the nearest go.mod ancestor at or above <dir>
# (= the sub-module that owns it), or nothing if it belongs to the root module.
# Pure-Bash walk-up, no dirname subprocess.
_sub_module_root() {
  local cur="${1%/}"
  while [[ -n "$cur" && "$cur" != "." ]]; do
    [[ -f "$cur/go.mod" ]] && { echo "$cur"; return; }
    if [[ "$cur" == */* ]]; then cur="${cur%/*}"; else cur="."; fi
  done
}

# _sub_module_rel_dirs <sub_root>: populate SUB_REL_DIRS with the staged dirs owned
# by <sub_root>, expressed relative to it ("." or "./sub/path"), so fmt/lint stay
# scoped to the staged change instead of the whole sub-module (./...).
_sub_module_rel_dirs() {
  local sub="$1" d
  SUB_REL_DIRS=()
  for d in "${STAGED_DIRS[@]+"${STAGED_DIRS[@]}"}"; do
    [[ "$(_sub_module_root "$d")" == "$sub" ]] || continue
    if [[ "$d" == "$sub" ]]; then
      SUB_REL_DIRS+=(".")
    else
      SUB_REL_DIRS+=("./${d#"$sub/"}")
    fi
  done
}

ROOT_DIRS=()
SUB_MODULE_ROOTS=()
for d in "${STAGED_DIRS[@]+"${STAGED_DIRS[@]}"}"; do
  sub_root="$(_sub_module_root "$d")"
  if [[ -n "$sub_root" ]]; then
    already=false
    for s in "${SUB_MODULE_ROOTS[@]+"${SUB_MODULE_ROOTS[@]}"}"; do
      [[ "$s" == "$sub_root" ]] && already=true && break
    done
    $already || SUB_MODULE_ROOTS+=("$sub_root")
  else
    ROOT_DIRS+=("./$d")
  fi
done

_label=""
[[ "${#ROOT_DIRS[@]}" -gt 0 ]] && _label+="${ROOT_DIRS[*]} "
[[ "${#SUB_MODULE_ROOTS[@]}" -gt 0 ]] && _label+="${SUB_MODULE_ROOTS[*]} (own module context)"
info "staged go dirs: ${_label:-<none>}"

# 2. License headers — add SPDX header where missing, then re-stage.
if skip license; then warn "SKIP=license"; else
  info "addlicense: ensuring SPDX headers"
  addlicense -f "$LICENSE_TMPL" "${STAGED_GO[@]}"
  git add -- "${STAGED_GO[@]}"
  ok "headers ensured + re-staged"
fi

# 3. Format — gofmt + goimports via golangci-lint v2, re-stage.
if skip format; then warn "SKIP=format"; else
  info "golangci-lint fmt"
  if [[ "${#ROOT_DIRS[@]}" -gt 0 ]]; then
    golangci-lint fmt -c "$GOLANGCI_CONFIG" "${ROOT_DIRS[@]}"
  fi
  for sub in "${SUB_MODULE_ROOTS[@]+"${SUB_MODULE_ROOTS[@]}"}"; do
    _sub_module_rel_dirs "$sub"
    (cd "$sub" && golangci-lint fmt -c "$REPO_ROOT/$GOLANGCI_CONFIG" "${SUB_REL_DIRS[@]}")
  done
  git add -- "${STAGED_GO[@]}"
  ok "formatted + re-staged"
fi

# 4. Lint — scoped to changed dirs, respecting module boundaries.
if skip lint; then warn "SKIP=lint"; else
  info "golangci-lint run (changed dirs)"
  lint_ok=true
  if [[ "${#ROOT_DIRS[@]}" -gt 0 ]]; then
    golangci-lint run -c "$GOLANGCI_CONFIG" --timeout="$GOLANGCI_TIMEOUT" "${ROOT_DIRS[@]}" \
      || lint_ok=false
  fi
  for sub in "${SUB_MODULE_ROOTS[@]+"${SUB_MODULE_ROOTS[@]}"}"; do
    _sub_module_rel_dirs "$sub"
    (cd "$sub" && golangci-lint run -c "$REPO_ROOT/$GOLANGCI_CONFIG" --timeout="$GOLANGCI_TIMEOUT" "${SUB_REL_DIRS[@]}") \
      || lint_ok=false
  done
  $lint_ok || die "lint issues (above). Fix and re-stage."
  ok "lint clean"
fi

# 5. go mod tidy check (repo-wide; fail-and-instruct, mirrors CI).
if skip mod; then warn "SKIP=mod"; else
  info "go mod tidy check"
  go mod tidy || die "go mod tidy failed (network? GOPROXY=$(go env GOPROXY)). Skip once: SKIP=mod"
  git diff --exit-code go.mod go.sum >/dev/null \
    || die "go.mod/go.sum not tidy — 'go mod tidy' updated them. Review, 'git add go.mod go.sum', recommit."
  ok "go.mod/go.sum tidy"
fi

# 6. go build (whole module; catches compile breakage).
if skip build; then warn "SKIP=build"; else
  info "go build ./..."
  go build ./... || die "go build failed (above)."
  ok "build ok"
fi

ok "pre-commit passed"
